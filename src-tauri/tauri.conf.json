{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Token Bubble 余量浮窗",
  "version": "0.1.5",
  "identifier": "app.quotafloat.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "widget",
        "title": "Token Bubble 余量浮窗",
        "width": 76,
        "height": 76,
        "minWidth": 76,
        "minHeight": 76,
        "maxWidth": 328,
        "maxHeight": 328,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true
      },
      {
        "label": "tray-panel",
        "title": "Token Bubble 余量浮窗",
        "url": "index.html?view=tray",
        "width": 380,
        "height": 504,
        "minWidth": 330,
        "minHeight": 430,
        "maxWidth": 720,
        "maxHeight": 820,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false,
        "visible": false
      }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'; img-src 'self' data:" }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "category": "Utility",
    "publisher": "Token Bubble contributors",
    "shortDescription": "Codex quota at a glance",
    "longDescription": "A lightweight floating desktop card for Codex usage limits.",
    "copyright": "Copyright Token Bubble contributors",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": {
      "resources/codexscope/": "codexscope/"
    }
  }
}
